# Copy to .env and fill in your values.

# --- DigitalOcean Gradient (serverless inference: vision + embeddings) ---
VISION_API_KEY=your-gradient-model-access-key
VISION_BASE_URL=https://inference.do-ai.run/v1
VISION_MODEL=openai-gpt-5.6-luna
# Must stay consistent across listings/search/wishlist (1024-dim; schema uses vector(1024))
EMBEDDING_MODEL=gte-large-en-v1.5

# --- Database (local dev: Homebrew Postgres; prod: DO Managed PostgreSQL URL) ---
DATABASE_URL=postgres://youruser@localhost:5432/ebroke_dev

# --- Sessions ---
SESSION_SECRET=generate-a-long-random-string

# --- DigitalOcean Spaces (photo storage, public-read bucket) ---
# Leave unset locally; POST /uploads/photo returns 503 until configured.
# SPACES_KEY=
# SPACES_SECRET=
# SPACES_REGION=sfo3
# SPACES_BUCKET=ebroke-photos
# SPACES_CDN_BASE_URL=https://ebroke-photos.sfo3.cdn.digitaloceanspaces.com

# --- Misc ---
# CORS_ORIGIN=http://localhost:5173
# WISHLIST_MATCH_THRESHOLD=0.65
# PORT=3000
